# Anthropic API Key (required for Claude AI analysis)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# GitHub Personal Access Token (optional for public repos, required for private)
# Create one at: https://github.com/settings/tokens
# Scopes needed: repo (for private repos), read:user
# Also enables live MCP GitHub tools for deeper analysis
GITHUB_TOKEN=ghp_...

# App URL (used for Vercel deployment metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000
